{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "inscription-americanfullfightingbons",
  "account_id": "<CLOUDFLARE_ACCOUNT_ID>",
  "main": "src/index.ts",
  "compatibility_date": "2025-12-17",
  "upload_source_maps": true,
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": [
      "/",
      "/inscription",
      "/inscription-config",
      "/api/*",
      "/mentions-legales"
    ]
  },
  "vars": {
    "APP_NAME": "AFFBC",
    "SIGNUP_ALERT_TO": "fullfightingbons@gmail.com",
    "SIGNUP_ALERT_FROM": "contact@americanfullfightingbons.fr",
    "SIGNUP_ALERT_SENDER_NAME": "AFFBC Inscriptions",
    "SIGNUP_ALERT_TO_NAME": "AFFBC",
    "PAYMENT_CURRENCY": "EUR",
    "HELLOASSO_ORGANIZATION_SLUG": "american-full-fighting-bons-en-chablais",
    "HELLOASSO_ENV": "production"
    // BANK_HOLDER / BANK_IBAN / BANK_BIC / BANK_NAME / BANK_ADDRESS /
    // BANK_TRANSFER_LABEL retirés : ce sont des "vars" versionnées en clair
    // dans ce fichier, donc jamais un bon endroit pour un IBAN réel. Le code
    // (inscription-config.js) lit déjà en priorité club_info.public_inscription_*
    // (table D1 partagée, éditable depuis l'admin gestion) — c'est ce chemin-là
    // qu'il faut utiliser pour activer le virement bancaire. Si un fallback via
    // variable d'environnement est vraiment nécessaire, utiliser
    // `wrangler secret put BANK_IBAN` (etc.) plutôt qu'une entrée ici.
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_id": "<AFFBC_PRODUCTION_DATABASE_ID>",
      "database_name": "affbc-production"
    }
  ],
  "r2_buckets": [
    {
      "binding": "R2_STORAGE",
      "bucket_name": "storage"
    },
    {
      "binding": "R2_PDF",
      "bucket_name": "fullfighting-pdf"
    }
  ],
  "observability": {
    "enabled": true
  },
  "triggers": {
    "crons": ["0 3 * * *"]
  }
}
